# Copy to .env and adjust. The defaults work for local web development.

# Port the auth server listens on.
PORT=8787

# WebAuthn Relying Party. For local dev the browser treats "localhost" as
# secure, so this works over http. In production, RP_ID is your bare domain
# (e.g. dosely.app) and ORIGIN is the full https URL the app is served from.
RP_ID=localhost
RP_NAME=DoselyAI

# Comma-separated list of allowed origins (the URLs your app is served from).
# Include every port your Expo web build might use.
ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:19006

# Secret used to sign session tokens. MUST be set to a long random value in
# production — generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=dev-only-insecure-change-me

# Anthropic API key for the hybrid chat's open-ended (LLM) answers. This is the
# app's single server-side key — users never provide their own. Get one at
# console.anthropic.com. Leave blank to keep AI chat off (medication and
# personal-data questions still work, answered locally).
ANTHROPIC_API_KEY=

